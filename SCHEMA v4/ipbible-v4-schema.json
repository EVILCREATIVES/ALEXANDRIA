{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://otherly-platform/schemas/ipbible-v4",
  "title": "IP Bible V4 Schema",
  "description": "Schema for IP Bible V4 format — modular domains, flattened structure (levels in metadata), FACTIONS and TONE promoted to top-level, WORLD.Stage added, LORE restructured",
  "type": "object",
  "required": ["version"],
  "properties": {
    "version": {
      "type": "integer",
      "const": 4
    },
    "OVERVIEW": {
      "$ref": "#/definitions/Overview"
    },
    "CHARACTERS": {
      "$ref": "#/definitions/Characters"
    },
    "WORLD": {
      "$ref": "#/definitions/World"
    },
    "LORE": {
      "$ref": "#/definitions/Lore"
    },
    "FACTIONS": {
      "$ref": "#/definitions/Factions"
    },
    "STYLE": {
      "$ref": "#/definitions/Style"
    },
    "TONE": {
      "$ref": "#/definitions/Tone"
    },
    "STORY": {
      "$ref": "#/definitions/Story"
    }
  },
  "additionalProperties": false,

  "definitions": {

    "Asset": {
      "type": "object",
      "required": ["url", "source"],
      "properties": {
        "url": {
          "type": "string"
        },
        "source": {
          "type": "string",
          "enum": ["uploaded", "extracted", "generated"]
        },
        "caption": {
          "type": "string"
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Image-level tags describing visual content"
        },
        "negativeTags": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Negative tags for image generation"
        },
        "trigger": {
          "type": "string",
          "description": "Trigger word for this specific image"
        },
        "_matchConfidence": {
          "type": "number"
        },
        "_matchReason": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },

    "Gen": {
      "type": "object",
      "properties": {
        "Trigger": {
          "type": "string"
        },
        "Tags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "NegativeTags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "Notes": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },

    "RelationshipLink": {
      "type": "object",
      "properties": {
        "TargetRef": {
          "type": "string"
        },
        "Type": {
          "type": "string"
        },
        "Directionality": {
          "type": "string"
        },
        "TensionLevel": {
          "type": "string",
          "enum": ["low", "medium", "high", "volatile"]
        },
        "KeyTurningPoints": {
          "type": "array",
          "items": { "type": "string" }
        },
        "Notes": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },

    "Relationships": {
      "type": "object",
      "properties": {
        "Link": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/RelationshipLink"
          }
        }
      },
      "additionalProperties": false
    },

    "Overview": {
      "type": "object",
      "properties": {
        "HeroPrompt": {
          "type": "string"
        },
        "HeroImage": {
          "oneOf": [
            { "$ref": "#/definitions/Asset" },
            { "type": "null" }
          ]
        },
        "IPTitle": {
          "type": "string"
        },
        "Logline": {
          "type": "string"
        },
        "Concept": {
          "type": "string"
        },
        "MainCharacter": {
          "type": "string"
        },
        "WhatUpAgainst": {
          "type": "string"
        },
        "Synopsis": {
          "type": "string"
        },
        "World": {
          "type": "string"
        },
        "Tone": {
          "type": "string"
        },
        "ImagesList": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/OverviewImageGroup"
          }
        }
      },
      "additionalProperties": false
    },

    "OverviewImageGroup": {
      "type": "object",
      "properties": {
        "Images": {
          "type": "object",
          "properties": {
            "SupportingImages": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/Asset"
              }
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },

    "CharacterImages": {
      "type": "object",
      "properties": {
        "LeadImage": {
          "oneOf": [
            { "$ref": "#/definitions/Asset" },
            { "type": "null" }
          ]
        },
        "FullBodyImage": {
          "oneOf": [
            { "$ref": "#/definitions/Asset" },
            { "type": "null" }
          ]
        },
        "SupportingImages": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Asset"
          }
        },
        "PoseSheet": {
          "oneOf": [
            { "$ref": "#/definitions/Asset" },
            { "type": "null" }
          ]
        },
        "ClothesImgs": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Asset"
          }
        },
        "PropImgs": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Asset"
          }
        },
        "DetailImgs": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Asset"
          }
        }
      },
      "additionalProperties": false
    },

    "IdentityRole": {
      "type": "object",
      "properties": {
        "NameLabel": {
          "type": "string"
        },
        "AliasesNicknames": {
          "type": "array",
          "items": { "type": "string" }
        },
        "StoryFunctionTag": {
          "type": "string"
        },
        "Status": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },

    "Visual": {
      "type": "object",
      "properties": {
        "AgeRange": {
          "type": "string"
        },
        "BodyType": {
          "type": "string",
          "enum": ["ectomorph", "mesomorph", "endomorph", "blend"]
        },
        "BodyShape": {
          "type": "string"
        },
        "KeyFacialPhysicalTraits": {
          "type": "array",
          "items": { "type": "string" }
        },
        "Hairstyle": {
          "type": "string"
        },
        "ClothingStyle": {
          "type": "string"
        },
        "KeyPropsSilhouetteHook": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },

    "Voice": {
      "type": "object",
      "properties": {
        "BaselineVoice": {
          "type": "string"
        },
        "SyntaxTempo": {
          "type": "string"
        },
        "Register": {
          "type": "string"
        },
        "SlangDialect": {
          "type": "string"
        },
        "SignaturePhrasesVerbalTics": {
          "type": "array",
          "items": { "type": "string" }
        },
        "AudioSample": {
          "oneOf": [
            { "$ref": "#/definitions/Asset" },
            { "type": "null" }
          ]
        }
      },
      "additionalProperties": false
    },

    "BehaviourRules": {
      "type": "object",
      "properties": {
        "CoreMotivations": {
          "type": "array",
          "items": { "type": "string" }
        },
        "CoreFearsVulnerabilities": {
          "type": "array",
          "items": { "type": "string" }
        },
        "AlwaysRules": {
          "type": "array",
          "items": { "type": "string" }
        },
        "NeverRules": {
          "type": "array",
          "items": { "type": "string" }
        },
        "PrimaryFlaws": {
          "type": "array",
          "items": { "type": "string" }
        },
        "DecisionPatterns": {
          "type": "string"
        },
        "HowTheyAct": {
          "type": "array",
          "items": { "type": "string" }
        },
        "HowTheyThink": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },

    "Character": {
      "type": "object",
      "properties": {
        "RoleType": {
          "type": "string",
          "enum": ["lead", "antagonist", "supporting", "background_recurring"]
        },
        "Name": {
          "type": "string"
        },
        "Aliases": {
          "type": "array",
          "items": { "type": "string" }
        },
        "StoryFunctionTags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "Logline": {
          "type": "string"
        },
        "Images": {
          "$ref": "#/definitions/CharacterImages"
        },
        "HowTheyLook": {
          "type": "array",
          "items": { "type": "string" }
        },
        "HowTheySpeak": {
          "type": "array",
          "items": { "type": "string" }
        },
        "SummaryBox": {
          "type": "string"
        },
        "Distinctiveness": {
          "type": "string"
        },
        "Comparison": {
          "type": "string"
        },
        "TheirQuestion": {
          "type": "string"
        },
        "WantAndNeed": {
          "type": "string"
        },
        "InnerPressure": {
          "type": "string"
        },
        "OuterPressure": {
          "type": "string"
        },
        "CoreBelief": {
          "type": "string"
        },
        "FactionAffiliation": {
          "type": "array",
          "items": { "type": "string" }
        },
        "KeyRelationships": {
          "type": "array",
          "items": { "type": "string" }
        },
        "Gen": {
          "$ref": "#/definitions/Gen"
        },
        "IdentityRole": {
          "$ref": "#/definitions/IdentityRole"
        },
        "SupportingImages": {
          "type": "object",
          "properties": {
            "SupportingImages": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/Asset"
              }
            }
          },
          "additionalProperties": false
        },
        "Visual": {
          "$ref": "#/definitions/Visual"
        },
        "Voice": {
          "$ref": "#/definitions/Voice"
        },
        "BehaviourRules": {
          "$ref": "#/definitions/BehaviourRules"
        },
        "Relationships": {
          "$ref": "#/definitions/Relationships"
        }
      },
      "additionalProperties": false
    },

    "Characters": {
      "type": "object",
      "properties": {
        "HeroPrompt": {
          "type": "string"
        },
        "Hero": {
          "oneOf": [
            { "$ref": "#/definitions/Asset" },
            { "type": "null" }
          ]
        },
        "CharacterList": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Character"
          }
        }
      },
      "additionalProperties": false
    },

    "AestheticLanguage": {
      "type": "object",
      "properties": {
        "Keywords": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },

    "WorldStage": {
      "type": "object",
      "description": "The primary world stage — the macro setting the IP lives inside",
      "properties": {
        "WorldStage": {
          "type": "string"
        },
        "Setting": {
          "type": "string"
        },
        "Role": {
          "type": "array",
          "items": { "type": "string" }
        },
        "HeroImage": {
          "oneOf": [
            { "$ref": "#/definitions/Asset" },
            { "type": "null" }
          ]
        },
        "SecondaryImages": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Asset"
          }
        },
        "SettingSummary": {
          "type": "string"
        },
        "Distinctiveness": {
          "type": "string"
        },
        "LocationRules": {
          "type": "array",
          "items": { "type": "string" }
        },
        "LocationPressures": {
          "type": "array",
          "items": { "type": "string" }
        },
        "ScaleAndStoryFocus": {
          "type": "string"
        },
        "Atmosphere": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },

    "LocationMeta": {
      "type": "object",
      "properties": {
        "Scale": {
          "type": "string",
          "enum": ["continent", "country", "region", "city", "neighborhood", "building", "room"]
        },
        "Context": {
          "type": "string"
        },
        "EnvironmentArchetype": {
          "type": "array",
          "items": { "type": "string" }
        },
        "Style": {
          "type": "array",
          "items": { "type": "string" }
        },
        "Function": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },

    "LocationImages": {
      "type": "object",
      "properties": {
        "LeadImage": {
          "oneOf": [
            { "$ref": "#/definitions/Asset" },
            { "type": "null" }
          ]
        },
        "SupportingImages": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Asset"
          }
        },
        "Map": {
          "oneOf": [
            { "$ref": "#/definitions/Asset" },
            { "type": "null" }
          ]
        },
        "PreProductionImages": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Asset"
          }
        }
      },
      "additionalProperties": false
    },

    "LocationName": {
      "type": "object",
      "properties": {
        "NameLabel": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },

    "Location": {
      "type": "object",
      "properties": {
        "LocationTier": {
          "type": "string",
          "enum": ["master", "secondary"]
        },
        "Name": {
          "oneOf": [
            { "$ref": "#/definitions/LocationName" },
            { "type": "string" }
          ]
        },
        "Type": {
          "type": "string"
        },
        "Role": {
          "type": "array",
          "items": { "type": "string" }
        },
        "SummaryBox": {
          "type": "string"
        },
        "Distinctiveness": {
          "type": "string"
        },
        "Comps": {
          "type": "string"
        },
        "Setting": {
          "type": "string"
        },
        "Images": {
          "$ref": "#/definitions/LocationImages"
        },
        "Meta": {
          "$ref": "#/definitions/LocationMeta"
        },
        "Position": {
          "type": "string"
        },
        "ShortDescription": {
          "type": "string"
        },
        "LocationPressures": {
          "type": "array",
          "items": { "type": "string" }
        },
        "LocationRules": {
          "type": "array",
          "items": { "type": "string" }
        },
        "HowItLooks": {
          "type": "array",
          "items": { "type": "string" }
        },
        "HowItFeels": {
          "type": "array",
          "items": { "type": "string" }
        },
        "ConnectedPeople": {
          "type": "array",
          "items": { "type": "string" }
        },
        "ConnectedPlaces": {
          "type": "array",
          "items": { "type": "string" }
        },
        "Gen": {
          "$ref": "#/definitions/Gen"
        },
        "Relationships": {
          "$ref": "#/definitions/Relationships"
        }
      },
      "additionalProperties": false
    },

    "World": {
      "type": "object",
      "properties": {
        "HeroPrompt": {
          "type": "string"
        },
        "Hero": {
          "oneOf": [
            { "$ref": "#/definitions/Asset" },
            { "type": "null" }
          ]
        },
        "WorldPremiseTone": {
          "type": "string"
        },
        "AestheticLanguage": {
          "$ref": "#/definitions/AestheticLanguage"
        },
        "Stage": {
          "$ref": "#/definitions/WorldStage"
        },
        "Locations": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Location"
          }
        }
      },
      "additionalProperties": false
    },

    "LoreSummarySection": {
      "type": "object",
      "description": "Reusable section shape for WhoRunsThings, HowTheWorldWorks, WhatPeopleBelieve, WhereItsBreaking",
      "properties": {
        "Themes": {
          "type": "string"
        },
        "Summary": {
          "type": "string"
        },
        "Images": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Asset"
          }
        }
      },
      "additionalProperties": false
    },

    "LoreHistory": {
      "type": "object",
      "properties": {
        "HowWeGotHere": {
          "type": "string"
        },
        "Timeline": {
          "type": "array",
          "items": { "type": "string" }
        },
        "TimelineImages": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Asset"
          }
        }
      },
      "additionalProperties": false
    },

    "LoreEntryLookAndFeel": {
      "type": "object",
      "properties": {
        "Images": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Asset"
          }
        },
        "PreProductionImages": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Asset"
          }
        },
        "WhereYouSeeIt": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },

    "LoreEntryRelationships": {
      "type": "object",
      "properties": {
        "ConnectedCharacters": {
          "type": "array",
          "items": { "type": "string" }
        },
        "ConnectedLocations": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },

    "LoreEntry": {
      "type": "object",
      "properties": {
        "Name": {
          "type": "string"
        },
        "Type": {
          "type": "string",
          "enum": ["SYSTEM", "EVENT", "PLACE", "OBJECT", "BELIEF"]
        },
        "Role": {
          "type": "array",
          "items": { "type": "string" }
        },
        "OneLine": {
          "type": "string"
        },
        "HeroImage": {
          "oneOf": [
            { "$ref": "#/definitions/Asset" },
            { "type": "null" }
          ]
        },
        "WhatItIs": {
          "type": "string"
        },
        "HowItWorks": {
          "type": "array",
          "items": { "type": "string" }
        },
        "WhoBenefitsWhoPays": {
          "type": "array",
          "items": { "type": "string" }
        },
        "PressurePoints": {
          "type": "array",
          "items": { "type": "string" }
        },
        "LookAndFeel": {
          "$ref": "#/definitions/LoreEntryLookAndFeel"
        },
        "Relationships": {
          "$ref": "#/definitions/LoreEntryRelationships"
        }
      },
      "additionalProperties": false
    },

    "LoreSummaryIntro": {
      "type": "object",
      "description": "Intro header for the LORE section — overview themes and preview",
      "properties": {
        "OverviewThemes": {
          "type": "string"
        },
        "HeroImage": {
          "oneOf": [
            { "$ref": "#/definitions/Asset" },
            { "type": "null" }
          ]
        },
        "Themes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "LoreOverview": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },

    "Lore": {
      "type": "object",
      "properties": {
        "HeroPrompt": {
          "type": "string"
        },
        "Hero": {
          "oneOf": [
            { "$ref": "#/definitions/Asset" },
            { "type": "null" }
          ]
        },
        "Summary": {
          "$ref": "#/definitions/LoreSummaryIntro"
        },
        "WhoRunsThings": {
          "$ref": "#/definitions/LoreSummarySection"
        },
        "HowTheWorldWorks": {
          "$ref": "#/definitions/LoreSummarySection"
        },
        "WhatPeopleBelieve": {
          "$ref": "#/definitions/LoreSummarySection"
        },
        "WhereItsBreaking": {
          "$ref": "#/definitions/LoreSummarySection"
        },
        "History": {
          "$ref": "#/definitions/LoreHistory"
        },
        "Entries": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/LoreEntry"
          }
        }
      },
      "additionalProperties": false
    },

    "FactionLookAndFeel": {
      "type": "object",
      "properties": {
        "VisualIdentity": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Asset"
          }
        },
        "PreProductionImages": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Asset"
          }
        },
        "TrademarkItems": {
          "type": "array",
          "items": { "type": "string" }
        },
        "HowTheyShowUp": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },

    "FactionRelationships": {
      "type": "object",
      "properties": {
        "ConnectedCharacters": {
          "type": "array",
          "items": { "type": "string" }
        },
        "ConnectedLocations": {
          "type": "array",
          "items": { "type": "string" }
        },
        "ConnectedLoreEntries": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
