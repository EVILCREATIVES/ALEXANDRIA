    "Faction": {
      "type": "object",
      "properties": {
        "Name": {
          "type": "string"
        },
        "FactionType": {
          "type": "string",
          "enum": ["GOVERNMENT", "CORPORATION", "CRIMINAL", "RELIGIOUS", "MILITARY", "SOCIAL", "IDEOLOGICAL", "OTHER"]
        },
        "OneLine": {
          "type": "string"
        },
        "HeroImage": {
          "oneOf": [
            { "$ref": "#/definitions/Asset" },
            { "type": "null" }
          ]
        },
        "WhoTheyAre": {
          "type": "string"
        },
        "WhatTheyWant": {
          "type": "string"
        },
        "HowTheyOperate": {
          "type": "array",
          "items": { "type": "string" }
        },
        "WhatTheyControl": {
          "type": "array",
          "items": { "type": "string" }
        },
        "InternalPressure": {
          "type": "array",
          "items": { "type": "string" }
        },
        "WhoBenefitsWhoPays": {
          "type": "array",
          "items": { "type": "string" }
        },
        "LookAndFeel": {
          "$ref": "#/definitions/FactionLookAndFeel"
        },
        "Relationships": {
          "$ref": "#/definitions/FactionRelationships"
        }
      },
      "additionalProperties": false
    },

    "Factions": {
      "type": "object",
      "description": "Top-level domain — create a FACTION only if recurring, story-driving, or explains major world pressure; otherwise keep as sublevel under LORE",
      "properties": {
        "HeroPrompt": {
          "type": "string"
        },
        "Hero": {
          "oneOf": [
            { "$ref": "#/definitions/Asset" },
            { "type": "null" }
          ]
        },
        "Faction": {
          "type": "array",
          "items": {
